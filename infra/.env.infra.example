# Infrastructure configuration for GCP setup
# Copy to .env.infra and fill in values (never commit .env.infra)

# GCP project ID
GCP_PROJECT=your-gcp-project-id

# GCP region for Cloud Run
GCP_REGION=us-central1

# Cloud Run service name
SERVICE_NAME=voicekit-backend

# Service account name (short name, not email)
SA_NAME=voicekit-sa

# ── Secrets to store in Secret Manager ────────────────────────────────────────

# Gemini API key
GEMINI_API_KEY=

# Google OAuth client credentials (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Restrict sign-in to this domain (e.g. yourcompany.com). Leave empty to allow any Google account.
ALLOWED_DOMAIN=yourcompany.com

# Basecamp OAuth (optional — leave blank to skip)
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=
BASECAMP_ACCOUNT_ID=

# Cloud SQL connection URL (leave empty to use SQLite — NOT suitable for production)
# Format: postgresql+asyncpg://user:password@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
DB_URL=
