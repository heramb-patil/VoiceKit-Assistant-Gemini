# VoiceKit SaaS Backend — Environment Variables
# Copy to .env and fill in your values.

# ── Gemini / AI ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-google-api-key  # Alternative to GEMINI_API_KEY

# ── SaaS Authentication ───────────────────────────────────────────────────────
# Google OAuth2 client ID (used to verify frontend ID tokens from @react-oauth/google)
GEMINI_LIVE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Restrict sign-in to this Google Workspace domain (leave empty to allow any Google account)
GEMINI_LIVE_ALLOWED_DOMAIN=yourcompany.com

# Public URL of this backend (used as OAuth redirect_uri for integration flows)
GEMINI_LIVE_BACKEND_PUBLIC_URL=http://localhost:8001

# Frontend URL (used for post-OAuth redirect after Google/Basecamp connect)
GEMINI_LIVE_FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# Leave empty to use SQLite (default). For Cloud SQL:
# GEMINI_LIVE_DB_URL=postgresql+asyncpg://user:pass@/dbname?host=/cloudsql/project:region:instance
GEMINI_LIVE_DB_URL=

# SQLite fallback path (used when DB_URL is empty)
GEMINI_LIVE_VOICEKIT_DB_PATH=./data/voicekit.db

# ── Google Integration OAuth ──────────────────────────────────────────────────
# Download from Google Cloud Console → APIs & Services → Credentials
# Create OAuth 2.0 Client ID of type "Web application"
# Add redirect URI: {BACKEND_PUBLIC_URL}/gemini-live/auth/google/callback
# GOOGLE_CREDENTIALS_FILE path (default: integrations/google/credentials/google_credentials.json)

# ── Basecamp Integration ─────────────────────────────────────────────────────
BASECAMP_CLIENT_ID=your-basecamp-client-id
BASECAMP_CLIENT_SECRET=your-basecamp-client-secret
BASECAMP_USER_AGENT=YourApp (your@email.com)
# Basecamp redirect URI to register: {BACKEND_PUBLIC_URL}/gemini-live/auth/basecamp/callback

# ── Server ────────────────────────────────────────────────────────────────────
GEMINI_LIVE_HOST=0.0.0.0
GEMINI_LIVE_PORT=8001
GEMINI_LIVE_LOG_LEVEL=INFO

# ── CORS ─────────────────────────────────────────────────────────────────────
# GEMINI_LIVE_CORS_ORIGINS=["https://your-app.web.app","http://localhost:3000"]
GEMINI_LIVE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Optional: Search providers ────────────────────────────────────────────────
# TAVILY_API_KEY=your-tavily-api-key
# SERPER_API_KEY=your-serper-api-key
