# Frontend Configuration
# Copy to .env.local and fill in values

# Google OAuth Client ID (same as backend — from Google Cloud Console)
REACT_APP_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Your Gemini API key (from https://aistudio.google.com/apikey)
REACT_APP_GEMINI_API_KEY=your-gemini-api-key-here

# Backend URL (default works for local dev; set to Cloud Run URL in production)
REACT_APP_VOICEKIT_API_URL=http://localhost:8001
